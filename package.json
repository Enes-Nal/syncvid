{
  "name": "syncweb",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @syncweb/server\" \"npm run dev -w @syncweb/web\"",
    "build": "npm run build --workspaces",
    "build:server": "npm run build -w @syncweb/shared && npm run build -w @syncweb/server",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.2"
  }
}
